# ============================================================
# KasAI — Environment Variables
# Copy file ini ke .env.local dan isi nilainya
# ============================================================

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon / Supabase / Railway)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# ─── Better Auth ─────────────────────────────────────────────────────────────
# URL aplikasi
# Development: http://localhost:3000
# Production:  https://yourdomain.com
BETTER_AUTH_URL=http://localhost:3000

# Secret key (min 32 karakter, random)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Buat bot di: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN

# Secret untuk validasi webhook Telegram (wajib diset di production!)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Daftarkan ke Telegram saat setWebhook:
#   curl -X POST https://api.telegram.org/bot<TOKEN>/setWebhook \
#     -d url=https://yourdomain.com/api/telegram \
#     -d secret_token=<TELEGRAM_WEBHOOK_SECRET>
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_HEX_SECRET

# ─── Admin ───────────────────────────────────────────────────────────────────
# Secret untuk endpoint /api/admin/create-user (kirim di header x-admin-secret)
ADMIN_SECRET=REPLACE_WITH_STRONG_ADMIN_SECRET
